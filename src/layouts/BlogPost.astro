---
import { type CollectionEntry, render } from "astro:content";
import { getAllPosts } from "@/data/post";
import calcReadingTime from "reading-time";

import Masthead from "@/components/blog/Masthead.astro";
import TOC from "@/components/blog/TOC.astro";
import WebMentions from "@/components/blog/webmentions/index.astro";
import Giscus from "@/components/blog/Giscus.astro";

import BaseLayout from "./Base.astro";

interface Props {
	post: CollectionEntry<"post">;
}

const { post } = Astro.props;
const { ogImage, tags, title, description, updatedDate, publishDate } = post.data;
const socialImage = ogImage ?? `/og-image/${post.id}.png`;
const articleDate = updatedDate?.toISOString() ?? publishDate.toISOString();
const { headings, remarkPluginFrontmatter } = await render(post);
const readingTime: string = remarkPluginFrontmatter.readingTime;

// 相關文章計算
const allPosts = await getAllPosts();
const otherPosts = allPosts.filter((p) => p.id !== post.id);
let relatedPosts: CollectionEntry<"post">[] = [];

if (otherPosts.length > 0) {
	// 先取同 tags 的文章
	const tagSet = new Set(tags);
	const taggedPosts = otherPosts.filter((p) =>
		p.data.tags.some((t: string) => tagSet.has(t))
	);

	// Fisher-Yates shuffle
	const shuffle = <T,>(arr: T[]): T[] => {
		const a = [...arr];
		for (let i = a.length - 1; i > 0; i--) {
			const j = Math.floor(Math.random() * (i + 1));
			[a[i], a[j]] = [a[j], a[i]];
		}
		return a;
	};

	const shuffledTagged = shuffle(taggedPosts);
	const shuffledOther = shuffle(otherPosts);

	// 合併：同 tags 的優先，不足的用隨機補足，取最多 3 篇
	const combined = shuffledTagged.concat(shuffledOther);
	const seen = new Set<string>();
	for (const p of combined) {
		if (!seen.has(p.id)) {
			seen.add(p.id);
			relatedPosts.push(p);
		}
		if (relatedPosts.length >= 3) break;
	}

}

function formatDate(date: Date): string {
	return date.toLocaleDateString("zh-TW", { year: "numeric", month: "long", day: "numeric" });
}
---

<BaseLayout
	meta={{
		articleDate,
		description,
		ogImage: socialImage,
		tags,
		title,
	}}
>
	<div id="reading-progress" role="progressbar" aria-valuemin={0} aria-valuemax={100} aria-valuenow={0} aria-label="Reading progress"></div>
	<article class="grow break-words" data-pagefind-body>
		<div id="blog-hero" class="mb-12"><Masthead content={post} readingTime={readingTime} /></div>
		<div class="flex flex-col gap-10 lg:flex-row lg:items-start lg:justify-between">
			<!-- Sidebar: TOC + Author Card -->
			<div class="hidden xl:block lg:sticky lg:top-12 lg:order-2 lg:-me-32 lg:basis-64">
				{!!headings.length && <TOC headings={headings} />}
				<!-- Author Info Card -->
				<div class="mb-4 rounded-xl bg-[--color-bg-alt] p-4">
					<p class="mb-2 text-xs font-semibold uppercase tracking-wide text-[--color-muted]">作者</p>
					<div class="flex items-center gap-3">
						<div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-[--color-accent] text-white font-bold">
							B
						</div>
						<div class="min-w-0">
							<p class="font-semibold text-[--color-text]">Benny</p>
							<p class="truncate text-xs text-[--color-muted]">前端工程師，熱愛開發工具與工作流程優化</p>
						</div>
					</div>
					<a
						aria-label="GitHub"
						class="mt-3 flex items-center gap-2 text-xs text-[--color-link] hover:underline"
						href="https://github.com/BennyTsai0711"
						rel="noopener noreferrer"
						target="_blank"
					>
						<svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
							<path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
						</svg>
						GitHub
					</a>
				</div>
			</div>
			<div
				class="prose prose-sm prose-headings:font-semibold prose-headings:text-accent-2 prose-headings:before:absolute prose-headings:before:-ms-4 prose-headings:before:text-muted prose-headings:hover:before:text-accent sm:prose-headings:before:content-['#'] sm:prose-th:before:content-none"
			>
				<slot />
				<WebMentions />

				{/* 社群分享按鈕 */}
				<div class="not-prose mt-10 flex flex-wrap items-center gap-3" id="share-buttons">
					<span class="me-1 text-sm font-medium text-[--color-muted]">分享：</span>

					<!-- Facebook -->
					<a
						aria-label="分享至 Facebook"
						class="flex h-9 w-9 items-center justify-center rounded-full bg-[--color-accent] text-white transition-all duration-200 hover:scale-110 hover:bg-[--color-accent-hover] hover:shadow-lg"
						href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.url.href)}`}
						rel="noopener noreferrer"
						target="_blank"
					>
						<svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
							<path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
						</svg>
					</a>

					<!-- Twitter / X -->
					<a
						aria-label="分享至 X (Twitter)"
						class="flex h-9 w-9 items-center justify-center rounded-full bg-[--color-link] text-white transition-all duration-200 hover:scale-110 hover:brightness-110 hover:shadow-lg"
						href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(Astro.url.href)}&text=${encodeURIComponent(title)}`}
						rel="noopener noreferrer"
						target="_blank"
					>
						<svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
							<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
						</svg>
					</a>

					<!-- LINE -->
					<a
						aria-label="分享至 LINE"
						class="flex h-9 w-9 items-center justify-center rounded-full bg-[#00B900] text-white transition-all duration-200 hover:scale-110 hover:brightness-110 hover:shadow-lg"
						href={`https://social-plugins.line.me/lineit/share?url=${encodeURIComponent(Astro.url.href)}`}
						rel="noopener noreferrer"
						target="_blank"
					>
						<svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
							<path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.627-.63h2.386c.349 0 .63.285.63.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.627-.63.349 0 .631.285.631.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314" fill="#00B900"/>
						</svg>
					</a>

					<!-- 複製連結 -->
					<button
						aria-label="複製連結"
						class="flex h-9 w-9 items-center justify-center rounded-full border-2 border-[--color-accent] text-[--color-accent] transition-all duration-200 hover:scale-110 hover:bg-[--color-accent] hover:text-white"
						id="copy-link-btn"
						type="button"
					>
						<svg class="h-4 w-4" fill="none" focusable="false" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
							<path d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" stroke-linecap="round" stroke-linejoin="round"/>
						</svg>
					</button>
				</div>

				{/* 複製提示 */}
				<div
					aria-live="polite"
					class="pointer-events-none fixed end-6 top-1/2 z-50 -translate-y-1/2 rounded-lg bg-[--color-accent] px-4 py-2 text-sm font-medium text-white opacity-0 shadow-xl transition-all duration-300"
					id="copy-toast"
					role="status"
				>
					已複製！
				</div>

				{/* 相關文章 */}
				{relatedPosts && relatedPosts.length > 0 && (
					<aside class="not-prose mt-12 rounded-xl border border-[--color-border] bg-[--color-bg-secondary] p-6">
						<h2 class="mb-5 text-lg font-semibold text-[--color-text]">📚 相關文章</h2>
						<ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3" role="list">
							{relatedPosts.map((related) => {
								const rt = (related.data as any).readingTime ?? calcReadingTime(related.body ?? "").text;
								return (
									<li>
										<a
											class="group flex flex-col gap-1.5 rounded-lg border border-transparent p-3 transition-all duration-200 hover:border-[--color-accent] hover:bg-[--color-bg] hover:shadow-md"
											href={`/posts/${related.id}/`}
										>
											<span class="line-clamp-2 text-sm font-medium leading-snug text-[--color-text] group-hover:text-[--color-accent]">
												{related.data.title}
											</span>
											<span class="flex items-center gap-2 text-xs text-[--color-muted]">
												<time datetime={related.data.publishDate.toISOString()}>
													{formatDate(related.data.publishDate)}
												</time>
												<span>·</span>
												<span>{rt}</span>
											</span>
										</a>
									</li>
								);
							})}
						</ul>
					</aside>
				)}

				<Giscus />
			</div>
		</div>
	</article>
	<button
		class="hover:border-link fixed end-4 bottom-8 z-90 flex h-10 w-10 translate-y-28 cursor-pointer items-center justify-center rounded-full border-2 border-transparent bg-zinc-200 text-3xl opacity-0 transition-all transition-discrete duration-300 data-[show=true]:translate-y-0 data-[show=true]:opacity-100 sm:end-8 sm:h-12 sm:w-12 dark:bg-zinc-700"
		data-show="false"
		id="to-top-btn"
	>
		<span class="sr-only">Back to top</span>
		<svg
			aria-hidden="true"
			class="h-6 w-6"
			fill="none"
			focusable="false"
			stroke="currentColor"
			stroke-width="2"
			viewBox="0 0 24 24"
			xmlns="http://www.w3.org/2000/svg"
		>
			<path d="M4.5 15.75l7.5-7.5 7.5 7.5" stroke-linecap="round" stroke-linejoin="round"></path>
		</svg>
	</button>

	<!-- 圖片燈箱 -->
	<div
		aria-label="圖片燈箱"
		aria-modal="true"
		class="lightbox-overlay"
		id="lightbox"
		role="dialog"
	>
		<button
			aria-label="關閉燈箱"
			class="lightbox-close"
			id="lightbox-close"
			type="button"
		>
			<svg aria-hidden="true" class="h-6 w-6" fill="none" focusable="false" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
				<path d="M6 18L18 6M6 6l12 12" stroke-linecap="round" stroke-linejoin="round"></path>
			</svg>
		</button>
		<div class="lightbox-content">
			<img alt="" class="lightbox-img" id="lightbox-img" src="" />
		</div>
	</div>
</BaseLayout>

<script>
	const scrollBtn = document.getElementById("to-top-btn") as HTMLButtonElement;
	const targetHeader = document.getElementById("blog-hero") as HTMLDivElement;

	function callback(entries: IntersectionObserverEntry[]) {
		entries.forEach((entry) => {
			// only show the scroll to top button when the heading is out of view
			scrollBtn.dataset.show = (!entry.isIntersecting).toString();
		});
	}

	scrollBtn.addEventListener("click", () => {
		document.documentElement.scrollTo({ behavior: "smooth", top: 0 });
	});

	const observer = new IntersectionObserver(callback);
	observer.observe(targetHeader);

	// 閱讀進度條
	const progressBar = document.getElementById("reading-progress") as HTMLDivElement;
	const article = document.querySelector("article") as HTMLElement;

	function updateProgress() {
		if (!article || !progressBar) return;
		const articleTop = article.offsetTop;
		const articleHeight = article.offsetHeight;
		const windowHeight = window.innerHeight;
		const scrollY = window.scrollY;
		const progress = Math.min(100, Math.max(0, ((scrollY - articleTop + windowHeight * 0.1) / (articleHeight - windowHeight * 0.1)) * 100));
		progressBar.style.width = `${progress}%`;
		progressBar.setAttribute("aria-valuenow", String(Math.round(progress)));
		progressBar.classList.toggle("visible", progress > 0 && progress < 100);
	}

	window.addEventListener("scroll", updateProgress, { passive: true });
	updateProgress();

	// 複製連結功能
	const copyBtn = document.getElementById("copy-link-btn");
	const toast = document.getElementById("copy-toast");

	if (copyBtn && toast) {
		copyBtn.addEventListener("click", async () => {
			try {
				await navigator.clipboard.writeText(window.location.href);
			} catch {
				// Fallback for older browsers
				const textarea = document.createElement("textarea");
				textarea.value = window.location.href;
				textarea.style.position = "fixed";
				textarea.style.opacity = "0";
				document.body.appendChild(textarea);
				textarea.select();
				document.execCommand("copy");
				document.body.removeChild(textarea);
			}
			// 顯示提示
			toast.style.opacity = "1";
			toast.style.transform = "translateY(-50%) scale(1)";
			setTimeout(() => {
				toast.style.opacity = "0";
				toast.style.transform = "translateY(-50%) scale(0.9)";
			}, 2000);
		});
	}

	// ===== 圖片燈箱功能 =====
	const lightbox = document.getElementById("lightbox") as HTMLDivElement;
	const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement;
	const lightboxClose = document.getElementById("lightbox-close") as HTMLButtonElement;
	const prose = document.querySelector(".prose") as HTMLElement;

	function openLightbox(src: string, alt: string) {
		lightboxImg.src = src;
		lightboxImg.alt = alt;
		lightbox.classList.add("active");
		document.body.style.overflow = "hidden";
		lightboxClose.focus();
	}

	function closeLightbox() {
		lightbox.classList.remove("active");
		document.body.style.overflow = "";
		lightboxImg.src = "";
		lightboxImg.alt = "";
	}

	// 监听文章區塊內所有 img（排除 code 區塊內的圖片）
	if (prose) {
		prose.addEventListener("click", (e) => {
			const target = e.target as HTMLElement;
			if (target.tagName !== "IMG") return;
			// 排除 code, pre, a 標籤內的圖片
			const parent = target.closest("code, pre, a");
			if (parent) return;

			const src = (target as HTMLImageElement).src;
			const alt = (target as HTMLImageElement).alt || "";
			openLightbox(src, alt);
		});
	}

	// 點擊背景關閉
	lightbox.addEventListener("click", (e) => {
		if (e.target === lightbox) closeLightbox();
	});

	// 關閉按鈕
	lightboxClose.addEventListener("click", closeLightbox);

	// ESC 關閉
	document.addEventListener("keydown", (e) => {
		if (e.key === "Escape" && lightbox.classList.contains("active")) {
			closeLightbox();
		}
	});
</script>

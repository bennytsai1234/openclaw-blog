---
import { type CollectionEntry, render } from "astro:content";
import Giscus from "@/components/blog/Giscus.astro";
import Masthead from "@/components/blog/Masthead.astro";
import TOC from "@/components/blog/TOC.astro";
import WebMentions from "@/components/blog/webmentions/index.astro";
import { getAllPosts } from "@/data/post";
import { collectionDateSort } from "@/utils/date";

import BaseLayout from "./Base.astro";

interface Props {
	post: CollectionEntry<"post">;
}

const { post } = Astro.props;
const { ogImage, tags, title, description, updatedDate, publishDate } = post.data;
const socialImage = ogImage ?? `/og-image/${post.id}.png`;
const articleDate = updatedDate?.toISOString() ?? publishDate.toISOString();
const { headings, remarkPluginFrontmatter } = await render(post);
const readingTime: string = remarkPluginFrontmatter.readingTime;

// 相關文章計算
const allPosts = await getAllPosts();
const otherPosts = allPosts.filter((p) => p.id !== post.id);
let relatedPosts: CollectionEntry<"post">[] = [];

if (otherPosts.length > 0) {
	// 先取同 tags 的文章
	const tagSet = new Set(tags);
	const taggedPosts = otherPosts.filter((p) => p.data.tags.some((t: string) => tagSet.has(t)));
	const sortedTagged = taggedPosts.sort(collectionDateSort);
	const sortedOther = otherPosts.sort(collectionDateSort);

	// 合併：同 tags 的優先，不足的用最新文章補足，取最多 3 篇
	const combined = [...sortedTagged, ...sortedOther];
	const seen = new Set<string>();
	for (const p of combined) {
		if (!seen.has(p.id)) {
			seen.add(p.id);
			relatedPosts.push(p);
		}
		if (relatedPosts.length >= 3) break;
	}

	// 為相關文章附加 readingTime
	relatedPosts = (await Promise.all(
		relatedPosts.map(async (p) => {
			const { remarkPluginFrontmatter } = await render(p);
			return { ...p, rt: remarkPluginFrontmatter.readingTime as string };
		}),
	)) as typeof relatedPosts;
}

function formatDate(date: Date): string {
	return date.toLocaleDateString("zh-TW", { year: "numeric", month: "long", day: "numeric" });
}
---

<BaseLayout
	meta={{
		articleDate,
		description,
		ogImage: socialImage,
		tags,
		title,
	}}
>
	<div id="reading-progress" role="progressbar" aria-valuemin={0} aria-valuemax={100} aria-valuenow={0} aria-label="Reading progress"></div>
	
	<article class="w-full break-words" data-pagefind-body>
		<div id="blog-hero" class="mx-auto mb-8 w-full max-w-2xl sm:mb-10"><Masthead content={post} readingTime={readingTime} /></div>
		<div
			class="article-prose prose prose-lg mx-auto max-w-2xl [overflow-wrap:anywhere] prose-headings:font-bold prose-headings:text-accent-2 sm:prose-th:before:content-none"
		>
						<slot />
						
						<WebMentions />

						{/* 社群分享按鈕 */}
						<div class="not-prose mt-10 flex flex-wrap items-center gap-3 border-t border-accent/10 pt-6 sm:mt-12 sm:pt-8" id="share-buttons">
							<span class="me-2 text-[11px] font-semibold uppercase tracking-[0.22em] text-muted/55">Share</span>
							<!-- Facebook -->
							<a
								aria-label="分享至 Facebook"
								class="flex h-8 w-8 items-center justify-center rounded-full bg-accent/5 text-muted transition-all hover:bg-[#1877F2] hover:text-white"
								href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.url.href)}`}
								rel="noopener noreferrer"
								target="_blank"
							>
								<svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
									<path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
								</svg>
							</a>

							<!-- Twitter / X -->
							<a
								aria-label="分享至 X (Twitter)"
								class="flex h-8 w-8 items-center justify-center rounded-full bg-accent/5 text-muted transition-all hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black"
								href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(Astro.url.href)}&text=${encodeURIComponent(title)}`}
								rel="noopener noreferrer"
								target="_blank"
							>
								<svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24">
									<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
								</svg>
							</a>

							<!-- LINE -->
							<a
								aria-label="分享至 LINE"
								class="flex h-8 w-8 items-center justify-center rounded-full bg-accent/5 text-muted transition-all hover:bg-[#00B900] hover:text-white"
								href={`https://social-plugins.line.me/lineit/share?url=${encodeURIComponent(Astro.url.href)}`}
								rel="noopener noreferrer"
								target="_blank"
							>
								<svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
									<path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.627-.63h2.386c.349 0 .63.285.63.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0 .345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.627-.63.349 0 .631.285.631.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/>
								</svg>
							</a>

							<!-- 複製連結 -->
							<button
								aria-label="複製連結"
								class="flex h-8 w-8 items-center justify-center rounded-full bg-accent/5 text-muted transition-all hover:bg-accent hover:text-white"
								id="copy-link-btn"
								type="button"
							>
								<svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
									<path d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" stroke-linecap="round" stroke-linejoin="round"/>
								</svg>
							</button>
						</div>

						{/* 複製提示 */}
						<div
							aria-live="polite"
							class="pointer-events-none fixed end-6 top-1/2 z-50 -translate-y-1/2 rounded-lg bg-accent px-4 py-2 text-sm font-medium text-white opacity-0 shadow-xl transition-all duration-300"
							id="copy-toast"
							role="status"
						>
							已複製！
						</div>

						{/* 相關文章 */}
						{relatedPosts && relatedPosts.length > 0 && (
							<aside class="not-prose mt-14 rounded-2xl border border-accent/10 bg-accent-soft/20 p-6 sm:mt-16 sm:p-8">
								<h2 class="mb-5 text-[11px] font-semibold uppercase tracking-[0.22em] text-muted/55">相關文章</h2>
								<ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3" role="list">
									{relatedPosts.map((related) => {
										const rt = "rt" in related ? (related as any).rt : "未知";
										return (
											<li>
												<a
													class="group flex flex-col gap-2 rounded-xl transition-all duration-200"
													href={`/posts/${related.id}/`}
												>
													<span class="line-clamp-2 text-sm font-bold leading-snug text-accent-2 group-hover:text-accent transition-colors">
														{related.data.title}
													</span>
													<span class="flex items-center gap-2 text-[10px] font-medium uppercase tracking-wider text-muted/50">
														<time datetime={related.data.publishDate.toISOString()}>
															{formatDate(related.data.publishDate)}
														</time>
														<span>·</span>
														<span>{rt}</span>
													</span>
												</a>
											</li>
										);
									})}
								</ul>
							</aside>
						)}

				<div class="not-prose mt-14 border-t border-accent/10 pt-8 sm:mt-16">
					<Giscus />
				</div>
		</div>
	</article>

	{/* Fixed TOC: floats right of max-w-3xl body, only on wide screens */}
	{!!headings.length && (
		<aside
			aria-label="文章目錄"
			class="toc-float hidden xl:block"
		>
			<h2 class="mb-3 text-[10px] font-semibold uppercase tracking-[0.22em] text-muted/55">目錄</h2>
			<TOC headings={headings} />
		</aside>
	)}

	<button
		class="hover:border-link fixed end-4 bottom-8 z-90 flex h-10 w-10 translate-y-28 cursor-pointer items-center justify-center rounded-full border-2 border-transparent bg-zinc-200 text-3xl opacity-0 transition-all transition-discrete duration-300 data-[show=true]:translate-y-0 data-[show=true]:opacity-100 sm:end-8 sm:h-12 sm:w-12 dark:bg-zinc-700"
		data-show="false"
		id="to-top-btn"
	>
		<span class="sr-only">Back to top</span>
		<svg
			aria-hidden="true"
			class="h-6 w-6"
			fill="none"
			focusable="false"
			stroke="currentColor"
			stroke-width="2"
			viewBox="0 0 24 24"
			xmlns="http://www.w3.org/2000/svg"
		>
			<path d="M4.5 15.75l7.5-7.5 7.5 7.5" stroke-linecap="round" stroke-linejoin="round"></path>
		</svg>
	</button>

	<!-- 圖片燈箱 -->
	<div
		aria-label="圖片燈箱"
		aria-modal="true"
		class="lightbox-overlay"
		id="lightbox"
		role="dialog"
	>
		<button
			aria-label="關閉燈箱"
			class="lightbox-close"
			id="lightbox-close"
			type="button"
		>
			<svg aria-hidden="true" class="h-6 w-6" fill="none" focusable="false" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
				<path d="M6 18L18 6M6 6l12 12" stroke-linecap="round" stroke-linejoin="round"></path>
			</svg>
		</button>
		<div class="lightbox-content">
			<img alt="" class="lightbox-img" id="lightbox-img" src="" />
		</div>
	</div>
</BaseLayout>

<script>
	const scrollBtn = document.getElementById("to-top-btn") as HTMLButtonElement;
	const targetHeader = document.getElementById("blog-hero") as HTMLDivElement;

	function callback(entries: IntersectionObserverEntry[]) {
		entries.forEach((entry) => {
			// only show the scroll to top button when the heading is out of view
			scrollBtn.dataset.show = (!entry.isIntersecting).toString();
		});
	}

	scrollBtn.addEventListener("click", () => {
		document.documentElement.scrollTo({ behavior: "smooth", top: 0 });
	});

	const observer = new IntersectionObserver(callback);
	observer.observe(targetHeader);

	// 閱讀進度條
	const progressBar = document.getElementById("reading-progress") as HTMLDivElement;
	const article = document.querySelector("article") as HTMLElement;
	let hideTimer: ReturnType<typeof setTimeout> | null = null;

	function updateProgress() {
		if (!article || !progressBar) return;
		const articleTop = article.offsetTop;
		const articleHeight = article.offsetHeight;
		const windowHeight = window.innerHeight;
		const scrollY = window.scrollY;
		const scrollable = articleHeight - windowHeight;
		const progress = scrollable > 0
			? Math.min(100, Math.max(0, ((scrollY - articleTop) / scrollable) * 100))
			: 100;
		progressBar.style.width = `${progress}%`;
		progressBar.setAttribute("aria-valuenow", String(Math.round(progress)));

		// 進度 > 0 就顯示；到 100% 時延遲 800ms 再淡出
		if (progress > 0) {
			if (hideTimer) { clearTimeout(hideTimer); hideTimer = null; }
			progressBar.classList.add("visible");
		}
		if (progress >= 100) {
			hideTimer = setTimeout(() => {
				progressBar.classList.remove("visible");
			}, 800);
		}
	}

	window.addEventListener("scroll", updateProgress, { passive: true });
	updateProgress();

	// 複製連結功能
	const copyBtn = document.getElementById("copy-link-btn");
	const toast = document.getElementById("copy-toast");

	if (copyBtn && toast) {
		copyBtn.addEventListener("click", async () => {
			if (!("clipboard" in navigator) || !navigator.clipboard.writeText) return;
			await navigator.clipboard.writeText(window.location.href);
			// 顯示提示
			toast.style.opacity = "1";
			toast.style.transform = "translateY(-50%) scale(1)";
			// 按鈕變綠色打勾
			copyBtn.classList.add("bg-emerald-500", "border-emerald-500", "text-white");
			copyBtn.querySelector("svg")?.setAttribute("fill", "currentColor");
			setTimeout(() => {
				toast.style.opacity = "0";
				toast.style.transform = "translateY(-50%) scale(0.9)";
				copyBtn.classList.remove("bg-emerald-500", "border-emerald-500", "text-white");
			}, 2000);
		});
	}

	// ===== 圖片燈箱功能 =====
	const lightbox = document.getElementById("lightbox") as HTMLDivElement;
	const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement;
	const lightboxClose = document.getElementById("lightbox-close") as HTMLButtonElement;
	const prose = document.querySelector(".prose") as HTMLElement;

	function openLightbox(src: string, alt: string) {
		lightboxImg.src = src;
		lightboxImg.alt = alt;
		lightbox.classList.add("active");
		document.body.style.overflow = "hidden";
		lightboxClose.focus();
	}

	function closeLightbox() {
		lightbox.classList.remove("active");
		document.body.style.overflow = "";
		lightboxImg.src = "";
		lightboxImg.alt = "";
	}

	// 监听文章區塊內所有 img（排除 code 區塊內的圖片）
	if (prose) {
		prose.addEventListener("click", (e) => {
			const target = e.target as HTMLElement;
			if (target.tagName !== "IMG") return;
			// 排除 code, pre, a 標籤內的圖片
			const parent = target.closest("code, pre, a");
			if (parent) return;

			const src = (target as HTMLImageElement).src;
			const alt = (target as HTMLImageElement).alt || "";
			openLightbox(src, alt);
		});
	}

	// 點擊背景關閉
	lightbox.addEventListener("click", (e) => {
		if (e.target === lightbox) closeLightbox();
	});

	// 關閉按鈕
	lightboxClose.addEventListener("click", closeLightbox);

	// ESC 關閉
	document.addEventListener("keydown", (e) => {
		if (e.key === "Escape" && lightbox.classList.contains("active")) {
			closeLightbox();
		}
	});

	// ===== TOC 主動態高亮 =====
	const tocLinks = document.querySelectorAll<HTMLAnchorElement>("[data-toc-slug]");
	if (tocLinks.length > 0) {
		const headingMap = new Map<string, HTMLAnchorElement>();
		tocLinks.forEach((link) => {
			const slug = link.dataset.tocSlug;
			if (slug) headingMap.set(slug, link);
		});

		// 替所有 heading 加上 id（以防萬一）
		document.querySelectorAll<HTMLElement>("h1[id], h2[id], h3[id], h4[id]").forEach((h) => {
			headingMap.set(h.id, document.querySelector(`[data-toc-slug="${h.id}"]`)!);
		});

		const observer = new IntersectionObserver(
			(entries) => {
				for (const entry of entries) {
					if (entry.isIntersecting) {
						const slug = entry.target.id;
						// 移除舊 active
						document.querySelectorAll(".toc-active").forEach((el) => el.classList.remove("toc-active"));
						// 加上新的 active
						const link = headingMap.get(slug);
						if (link) link.classList.add("toc-active");
					}
				}
			},
			{
				rootMargin: "-20% 0% -70% 0%",
				threshold: 0,
			}
		);

		document.querySelectorAll<HTMLElement>("h1[id], h2[id], h3[id], h4[id]").forEach((h) => {
			observer.observe(h);
		});
	}

	// ===== 寬圖片滿寬顯示 (US-014) =====
	const articleImgs = document.querySelectorAll<HTMLImageElement>(".prose img");
	articleImgs.forEach((img) => {
		const checkWidth = () => {
			if (img.naturalWidth > 700) {
				img.setAttribute("data-astro-image", "full-width");
			}
		};
		// 如果已經載入完成
		if (img.complete) {
			checkWidth();
		} else {
			img.addEventListener("load", checkWidth);
		}
	});
</script>

---
import { type CollectionEntry } from "astro:content";
import PostPreview from "@/components/blog/PostPreview.astro";
import SocialList from "@/components/SocialList.astro";
import { getAllPosts } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";
import { collectionDateSort } from "@/utils/date";

// Posts Data
const MAX_POSTS = 10;
const allPosts = await getAllPosts();
const allPostsByDate = allPosts.sort(collectionDateSort) as CollectionEntry<"post">[];

// Filter Tech Articles and AI News
const techPosts = allPostsByDate.filter((p) => !p.data.title.includes("精選"));
const aiPosts = allPostsByDate.filter((p) => p.data.title.includes("精選"));

const latestTechPosts = techPosts.slice(0, MAX_POSTS);
const latestAiPosts = aiPosts.slice(0, MAX_POSTS);

// Pinned Posts, set to a max of 3;
const MAX_PINNED_POSTS = 3;
const pinnedPosts = techPosts
	.values()
	.filter((p) => p.data.pinned)
	.take(MAX_PINNED_POSTS)
	.toArray();
---

<PageLayout meta={{ title: "首頁" }}>
	<!-- Hero Section -->
	<section class="mb-14 mt-4 flex flex-col items-center text-center sm:mb-20 sm:mt-8">
		<!-- Animated lobster logo -->
		<div class="mb-6 sm:mb-7">
			<svg
				aria-hidden="true"
				class="h-24 w-16 animate-float sm:h-28 sm:w-18"
				fill="none"
				focusable="false"
				viewBox="0 0 100 100"
				xmlns="http://www.w3.org/2000/svg"
			>
				<title>OpenClaw Lobster Logo</title>
				<ellipse cx="50" cy="55" rx="25" ry="20" fill="#e74c3c"/>
				<ellipse cx="50" cy="78" rx="12" ry="6" fill="#c0392b"/>
				<ellipse cx="50" cy="86" rx="8" ry="4" fill="#c0392b"/>
				<path d="M42 90 Q50 98 58 90" stroke="#c0392b" stroke-width="3" fill="none"/>
				<ellipse cx="50" cy="35" rx="18" ry="15" fill="#e74c3c"/>
				<circle cx="42" cy="30" r="4" fill="#2c3e50"/>
				<circle cx="58" cy="30" r="4" fill="#2c3e50"/>
				<circle cx="43" cy="29" r="1.5" fill="white"/>
				<circle cx="59" cy="29" r="1.5" fill="white"/>
				<path d="M42 22 Q35 10 30 5" stroke="#c0392b" stroke-width="2" fill="none"/>
				<path d="M58 22 Q65 10 70 5" stroke="#c0392b" stroke-width="2" fill="none"/>
				<ellipse cx="22" cy="50" rx="12" ry="8" fill="#e74c3c" transform="rotate(-20 22 50)"/>
				<path d="M12 45 Q5 40 8 35 Q12 38 12 45" fill="#c0392b"/>
				<path d="M12 55 Q5 60 8 65 Q12 62 12 55" fill="#c0392b"/>
				<ellipse cx="78" cy="50" rx="12" ry="8" fill="#e74c3c" transform="rotate(20 78 50)"/>
				<path d="M88 45 Q95 40 92 35 Q88 38 88 45" fill="#c0392b"/>
				<path d="M88 55 Q95 60 92 65 Q88 62 88 55" fill="#c0392b"/>
				<path d="M35 65 Q30 72 28 75" stroke="#c0392b" stroke-width="2" fill="none"/>
				<path d="M42 68 Q38 75 36 78" stroke="#c0392b" stroke-width="2" fill="none"/>
				<path d="M58 68 Q62 75 64 78" stroke="#c0392b" stroke-width="2" fill="none"/>
				<path d="M65 65 Q70 72 72 75" stroke="#c0392b" stroke-width="2" fill="none"/>
				<ellipse cx="45" cy="48" rx="8" ry="5" fill="#ff6b6b" opacity="0.5"/>
			</svg>
		</div>

		<!-- Title -->
		<h1 class="mb-4 text-4xl font-extrabold tracking-tight text-accent-2 sm:text-6xl">
			技術筆記
		</h1>

		<!-- Tagline -->
		<p class="mb-7 max-w-2xl text-lg leading-8 text-muted sm:mb-8 sm:text-xl">
			記錄開發過程中的所見所得，專注於前端技術、後端技術、網路技術、開發工具與工作流程優化。
		</p>

		<!-- Social links -->
		<div class="flex justify-center">
			<SocialList />
		</div>
	</section>

	{
		pinnedPosts.length > 0 && (
			<section class="mb-14 sm:mb-16">
				<h2 class="mb-6 text-[11px] font-semibold uppercase tracking-[0.22em] text-muted/55">置頂文章</h2>
				<ul class="space-y-4 sm:space-y-5" role="list">
					{pinnedPosts.map((p) => (
						<li class="grid gap-1 sm:grid-cols-[auto_1fr]">
							<PostPreview post={p} />
						</li>
					))}
				</ul>
			</section>
		)
	}
	<section class="mb-14 sm:mb-16">
		<h2 class="mb-6 text-[11px] font-semibold uppercase tracking-[0.22em] text-muted/55">
			<a class="hover:text-accent" href="/posts/">最新技術文章</a>
		</h2>
		<ul class="space-y-4 sm:space-y-5" role="list">
			{
				latestTechPosts.map((p) => (
					<li class="grid gap-1 sm:grid-cols-[auto_1fr]">
						<PostPreview post={p} />
					</li>
				)
			)}
		</ul>
	</section>
	{
		latestAiPosts.length > 0 && (
			<section class="mt-14 sm:mt-16">
				<h2 class="mb-6 text-[11px] font-semibold uppercase tracking-[0.22em] text-muted/55">
					<a class="hover:text-accent" href="/posts/">AI 產業動態專欄</a>
				</h2>
				<ul class="space-y-4 sm:space-y-5" role="list">
					{latestAiPosts.map((p) => (
						<li class="grid gap-1 sm:grid-cols-[auto_1fr]">
							<PostPreview post={p} />
						</li>
					))}
				</ul>
			</section>
		)
	}
</PageLayout>

<style>
	@keyframes float {
		0%, 100% {
			transform: translateY(0) rotate(0deg);
		}
		50% {
			transform: translateY(-8px) rotate(3deg);
		}
	}

	.animate-float {
		animation: float 4s ease-in-out infinite;
	}
</style>

---
import type { CollectionEntry } from "astro:content";
import type { GetStaticPaths, Page } from "astro";
import { Icon } from "astro-icon/components";
import getReadingTime from "reading-time";
import PostPreview from "@/components/blog/PostPreview.astro";
import Pagination from "@/components/Paginator.astro";
import { getAllPosts, getUniqueTags, groupPostsByYear } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";
import { collectionDateSort } from "@/utils/date";

export const getStaticPaths = (async ({ paginate }) => {
	const MAX_POSTS_PER_PAGE = 10;
	const MAX_TAGS = 7;
	const MAX_PINNED_POSTS = 3;
	const allPosts = await getAllPosts();
	const allPostsByDate = allPosts.sort(collectionDateSort);
	const uniqueTags = getUniqueTags(allPosts).slice(0, MAX_TAGS);
	const pinnedPosts = allPostsByDate
		.values()
		.filter((p) => p.data.pinned)
		.take(MAX_PINNED_POSTS)
		.toArray();
	return paginate(allPostsByDate, {
		pageSize: MAX_POSTS_PER_PAGE,
		props: { uniqueTags, pinnedPosts },
	});
}) satisfies GetStaticPaths;

interface Props {
	page: Page<CollectionEntry<"post">>;
	uniqueTags: string[];
	pinnedPosts: CollectionEntry<"post">[];
}

const { page, uniqueTags, pinnedPosts } = Astro.props;

const meta = {
	description: "所有文章列表，記錄開發所見所得",
	title: "所有文章",
};

const paginationProps = {
	...(page.url.prev && {
		prevUrl: {
			text: "← Previous Page",
			url: page.url.prev,
		},
	}),
	...(page.url.next && {
		nextUrl: {
			text: "Next Page →",
			url: page.url.next,
		},
	}),
};

const groupedByYear = groupPostsByYear(page.data);
const descYearKeys = Object.keys(groupedByYear).sort((a, b) => +b - +a);
---

<PageLayout meta={meta}>
	<div class="mb-7 flex items-center gap-3 sm:mb-8">
		<div class="flex-1">
			<h1 class="title text-accent mb-2 text-3xl">所有文章</h1>
			<p class="text-muted text-sm">共 {page.total} 篇文章</p>
		</div>
		<a class="text-accent transition-colors hover:text-accent-hover" href="/rss.xml" rel="noopener noreferrer" target="_blank">
			<span class="sr-only">RSS feed</span>
			<Icon aria-hidden="true" class="h-6 w-6" focusable="false" name="mdi:rss" />
		</a>
	</div>
	<div class="mb-7 flex flex-wrap gap-2" id="tag-filters">
		{uniqueTags.map((tag) => (
			<a
				class="tag-filter-btn rounded-full px-3 py-1 text-xs font-medium transition-all duration-200"
				href={`/tags/${tag}/`}
			>
				&#35;{tag}
			</a>
		))}
	</div>
	<div class="grid gap-y-10 sm:grid-cols-[minmax(0,1fr)_13rem] sm:gap-x-8 sm:gap-y-12">
		<div>
			{
				pinnedPosts.length > 0 && page.currentPage === 1 && (
					<section class="mb-14 sm:mb-16">
						<h2 class="mb-6 text-[11px] font-semibold uppercase tracking-[0.22em] text-muted/55">置頂文章</h2>
						<ul class="space-y-4" role="list">
							{pinnedPosts.map((p) => (
								<li class="grid gap-1 sm:grid-cols-[auto_1fr]">
									<PostPreview post={p} />
								</li>
							))}
						</ul>
					</section>
				)
			}
			{
				descYearKeys.map((yearKey) => (
					<section class="mb-14 sm:mb-16">
						<h2
							id={`year-${yearKey}`}
							class="mb-6 text-[11px] font-semibold uppercase tracking-[0.22em] text-muted/55"
						>
							{yearKey}
						</h2>
						<ul class="space-y-4 sm:space-y-5 text-start">
							{groupedByYear[yearKey]?.map((p) => (
								<li
									class="post-item rounded-xl border border-transparent bg-[--color-surface] p-4 transition-all duration-200 hover:border-accent/15 hover:bg-[--color-surface]/85 sm:p-5"
								>
									<div class="flex flex-col gap-2.5 sm:flex-row sm:items-start sm:gap-4">
										<div class="flex shrink-0 items-center gap-3 sm:flex-col sm:items-start sm:gap-1">
											<time
												class="text-accent text-sm font-semibold"
												datetime={p.data.publishDate.toISOString()}
											>
												{new Intl.DateTimeFormat("en-GB", { day: "numeric", month: "short", year: "numeric" }).format(p.data.publishDate)}
											</time>
											<span class="text-muted text-sm tabular-nums">
												{Math.ceil(getReadingTime(p.body ?? "").minutes)} min
											</span>
										</div>
										<div class="min-w-0 flex-1">
											<h3 class="mb-1.5 text-base font-semibold leading-6">
												<a class="cactus-link" href={`/posts/${p.id}/`}>
													{p.data.title}
												</a>
											</h3>
											{p.data.description && (
												<p class="text-muted mb-2.5 line-clamp-2 text-sm leading-6">
													{p.data.description}
												</p>
											)}
											{p.data.tags.length > 0 && (
												<div class="flex flex-wrap gap-1.5">
													{p.data.tags.map((tag) => (
														<span class="rounded-full bg-accent/10 px-2 py-0.5 text-[10px] font-medium text-accent">
															&#35;{tag}
														</span>
													))}
												</div>
											)}
										</div>
									</div>
								</li>
							))}
						</ul>
					</section>
				))
			}
			<Pagination {...paginationProps} />
		</div>
		{
			!!uniqueTags.length && (
				<aside>
					<h2 class="mb-4 flex items-center gap-1 text-[11px] font-semibold uppercase tracking-[0.22em] text-muted/55">
						<svg
							aria-hidden="true"
							class="h-4 w-4"
							fill="none"
							stroke="var(--color-muted)"
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="1.5"
							viewBox="0 0 24 24"
							xmlns="http://www.w3.org/2000/svg"
						>
							<path d="M0 0h24v24H0z" fill="none" stroke="none" />
							<path d="M7.859 6h-2.834a2.025 2.025 0 0 0 -2.025 2.025v2.834c0 .537 .213 1.052 .593 1.432l6.116 6.116a2.025 2.025 0 0 0 2.864 0l2.834 -2.834a2.025 2.025 0 0 0 0 -2.864l-6.117 -6.116a2.025 2.025 0 0 0 -1.431 -.593z" />
							<path d="M17.573 18.407l2.834 -2.834a2.025 2.025 0 0 0 0 -2.864l-7.117 -7.116" />
							<path d="M6 9h-.01" />
						</svg>
						標籤
					</h2>
					<ul class="flex flex-wrap gap-2">
						{uniqueTags.map((tag) => (
							<li>
								<a class="cactus-link flex items-center justify-center" href={`/tags/${tag}/`}>
									<span aria-hidden="true">#</span>
									<span class="sr-only">View all posts with the tag</span>
									{tag}
								</a>
							</li>
						))}
					</ul>
					<span class="mt-4 block text-sm sm:text-end">
						<a class="hover:text-link" href="/tags/">
							查看全部 <span aria-hidden="true">→</span>
							<span class="sr-only">blog tags</span>
						</a>
					</span>
				</aside>
			)
		}
	</div>
</PageLayout>

<style>
	.tag-filter-btn {
		background-color: var(--color-surface);
		color: var(--color-muted);
		border: 1px solid var(--color-surface-hover);
	}

	.tag-filter-btn:hover {
		background-color: var(--color-accent);
		color: white;
		border-color: var(--color-accent);
	}
</style>

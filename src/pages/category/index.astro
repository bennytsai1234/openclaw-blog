---
import { getAllPosts, getTagMeta, getUniqueTagsWithCount } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";

const allPosts = await getAllPosts();
const allTags = getUniqueTagsWithCount(allPosts);

// 每個 tag 的詳細資訊
const tagInfos = await Promise.all(
	allTags.map(async ([tag, count]) => {
		const tagMeta = await getTagMeta(tag);
		// 取該分類最新一篇文章的標題當「代表文章」
		const postsInTag = allPosts
			.filter((p) => p.data.tags.includes(tag))
			.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
		const latestPost = postsInTag[0];
		return {
			tag,
			count,
			title: tagMeta?.data.title ?? tag,
			description: tagMeta?.data.description ?? latestPost?.data.description ?? "",
			latestPostTitle: latestPost?.data.title,
			icon: tagMeta?.data.icon,
		};
	})
);

const meta = {
	description: "瀏覽所有文章分類，每個分類都有深入的技術介紹",
	title: "文章分類",
};
---

<PageLayout meta={meta}>
	<!-- Header -->
	<div class="mb-12">
		<h1 class="title mb-3 text-3xl">文章分類</h1>
		<p class="text-muted text-sm">
			這裡收藏了各個領域的技術筆記。共 <span class="text-accent font-semibold">{allTags.length}</span> 個分類，計 <span class="text-accent font-semibold">{allPosts.length}</span> 篇文章。
		</p>
	</div>

	<!-- 分類卡片網格 (Bento 風格) -->
	<div class="grid gap-6 sm:grid-cols-2">
		{
			tagInfos.map(({ tag, count, title, description, latestPostTitle, icon }) => (
				<a
					class="flex flex-col sm:flex-row gap-5 p-6 rounded-2xl border border-accent/5 bg-accent-soft/10 hover:border-accent/20 hover:bg-accent-soft/20 transition-all duration-300 group overflow-hidden"
					href={`/category/${tag}/`}
				>
					<!-- 圖示 -->
					<div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-accent/5 text-3xl transition-transform duration-500 group-hover:scale-110 sm:h-14 sm:w-14 mx-auto sm:mx-0">
						{icon || "📂"}
					</div>

					<!-- 內容 -->
					<div class="flex-1 min-w-0 flex flex-col">
						<div class="flex items-center justify-between mb-2.5 gap-3">
							<h2 class="font-bold text-lg text-accent-2 group-hover:text-accent transition-colors duration-300 truncate">
								{title}
							</h2>
							<span class="shrink-0 text-[10px] font-bold text-muted/40 uppercase tracking-widest">
								{count} Posts
							</span>
						</div>
						
						<p class="text-xs text-muted leading-relaxed mb-5 line-clamp-2 text-center sm:text-left font-medium">
							{description}
						</p>

						<!-- 底部：最新文章 -->
						{latestPostTitle && (
							<div class="mt-auto flex items-center gap-2 text-[10px] font-bold uppercase tracking-tighter text-muted/30 border-t border-accent/5 pt-3 transition-colors group-hover:border-accent/10">
								<span class="shrink-0 text-accent/60">LATEST</span>
								<span class="truncate min-w-0 group-hover:text-muted/60 transition-colors">{latestPostTitle}</span>
								<svg
									class="h-2.5 w-2.5 shrink-0 text-accent opacity-0 -translate-x-2 transition-all duration-300 group-hover:opacity-100 group-hover:translate-x-0 ml-auto"
									fill="none"
									viewBox="0 0 24 24"
									stroke="currentColor"
									stroke-width="3"
								>
									<path d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" stroke-linecap="round" stroke-linejoin="round"/>
								</svg>
							</div>
						)}
					</div>
				</a>
			))
		}
	</div>
</PageLayout>

---
import type { TocItem } from "@/utils/generateToc";

interface Props {
	heading: TocItem;
}

const {
	heading: { children, depth, slug, text },
} = Astro.props;
---

<li class={`${depth > 2 ? "ms-2" : ""}`}>
	<a
		class={`toc-link line-clamp-2 block py-1 transition-all duration-200 ${
			depth <= 2 ? "mt-3 font-medium" : "mt-1.5 text-xs text-muted"
		}`}
		data-toc-slug={slug}
		href={`#${slug}`}
	>
		<span aria-hidden="true" class="me-0.5 text-muted opacity-0 transition-opacity duration-200 toc-hash">#</span><span class="toc-text">{text}</span>
	</a>
	{
		!!children.length && (
			<ol>
				{children.map((subheading) => (
					<Astro.self heading={subheading} />
				))}
			</ol>
		)
	}
</li>

---
import type { CollectionEntry } from "astro:content";
import type { HTMLTag, Polymorphic } from "astro/types";
import getReadingTime from "reading-time";
import { displayTitle, displayDescription, displayTagName } from "@/utils/traditionalize";

type Props<Tag extends HTMLTag> = Polymorphic<{ as: Tag }> & {
	post: CollectionEntry<"post">;
	withDesc?: boolean;
};

const { as: Tag = "div", post, withDesc = false } = Astro.props;

const dateStr = new Intl.DateTimeFormat("en-GB", {
	day: "numeric",
	month: "short",
	year: "numeric",
}).format(post.data.publishDate);

const readingMins = Math.ceil(getReadingTime(post.body ?? "").minutes);
const readingTimeStr = `${readingMins} min`;

const displayTitleText = displayTitle(post.data.title);
const displayDesc = displayDescription(post.data.description);
---

<time
	class="text-accent min-w-28 shrink-0 pt-0.5 font-semibold text-sm"
	datetime={post.data.publishDate.toISOString()}
	title={post.data.publishDate.toISOString()}
>{dateStr}</time>
<Tag class="min-w-0 flex-1 leading-6">
	{post.data.draft && <span class="text-red-500">(Draft) </span>}
	<a class="font-semibold transition-colors duration-200 hover:text-accent" href={`/posts/${post.id}/`}>
		{displayTitleText}
	</a>
</Tag>
<span class="text-muted shrink-0 pt-0.5 text-sm tabular-nums">{readingTimeStr}</span>
{withDesc && <q class="line-clamp-3 italic">{displayDesc}</q>}

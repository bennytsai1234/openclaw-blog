---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

interface Props {
	content: CollectionEntry<"post">;
	readingTime: string;
}

const {
	content: { data },
	readingTime,
} = Astro.props;

const dateStr = new Intl.DateTimeFormat("en-GB", {
	day: "numeric",
	month: "short",
	year: "numeric",
}).format(data.publishDate);
---

{
	data.coverImage && (
		<div class="mb-6 aspect-video w-full">
			<Image
				alt={data.coverImage.alt}
				layout="constrained"
				width={748}
				height={420}
				priority
				src={data.coverImage.src}
			/>
		</div>
	)
}
{data.draft ? <span class="text-base text-red-500">(Draft)</span> : null}
<h1 class="title mb-3 w-full">
	{data.title}
</h1>
{data.description && (
	<p class="text-muted mb-4 w-full border-l-2 border-accent/40 pl-4 text-sm leading-relaxed italic">
		{data.description}
	</p>
)}
<div class="article-tags flex flex-wrap items-center gap-x-3 gap-y-1.5 border-b border-accent/10 pb-4 text-sm">
	<time class="text-accent font-semibold" datetime={data.publishDate.toISOString()}>
		{dateStr}
	</time>
	<span class="text-muted/40">·</span>
	<span class="text-muted">{readingTime}</span>
	{data.updatedDate && (
		<span class="rounded-full bg-emerald-100 px-2.5 py-0.5 text-xs font-medium text-emerald-700 dark:bg-emerald-900 dark:text-emerald-300">
			更新於 {new Intl.DateTimeFormat("zh-TW", { month: "short", day: "numeric" }).format(data.updatedDate)}
		</span>
	)}
	{!!data.tags?.length && data.tags.map((tag) => (
		<a data-pagefind-filter={`tag:${tag}`} href={`/tags/${tag}/`}>
			<span class="sr-only">View more blogs with the tag&nbsp;</span>{tag}
		</a>
	))}
</div>

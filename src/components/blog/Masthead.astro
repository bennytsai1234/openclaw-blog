---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

interface Props {
	content: CollectionEntry<"post">;
	readingTime: string;
}

const {
	content: { data },
	readingTime,
} = Astro.props;

const dateStr = new Intl.DateTimeFormat("zh-TW", {
	year: "numeric",
	month: "2-digit",
	day: "2-digit",
}).format(data.publishDate);
---

{
	data.coverImage && (
		<div class="mb-6 aspect-video w-full overflow-hidden rounded-2xl">
			<Image
				alt={data.coverImage.alt}
				layout="constrained"
				width={748}
				height={420}
				priority
				src={data.coverImage.src}
			/>
		</div>
	)
}
{data.draft ? <span class="text-base text-red-500">(Draft)</span> : null}
<h1 class="title mb-4 w-full text-3xl leading-tight sm:text-4xl">
	{data.title}
</h1>
{data.description && (
	<p class="text-muted mb-5 w-full max-w-[62ch] border-l-2 border-accent/35 pl-4 text-[1.02rem] leading-8 italic">
		{data.description}
	</p>
)}
<div class="article-tags flex flex-wrap items-center gap-x-3 gap-y-2 border-b border-accent/10 pb-5 text-sm sm:text-[0.95rem]">
	<time class="relative-time text-accent font-semibold tracking-[0.01em]" datetime={data.publishDate.toISOString()}>
		{dateStr}
	</time>
	<span class="text-muted/40">·</span>
	<span class="text-muted/90 text-[0.95rem]">📖 {readingTime}</span>
	{data.updatedDate && (
		<span class="rounded-full bg-emerald-100/80 px-2.5 py-1 text-[11px] font-medium text-emerald-700 dark:bg-emerald-900/50 dark:text-emerald-300">
			更新於 {new Intl.DateTimeFormat("zh-TW", { year: "numeric", month: "2-digit", day: "2-digit" }).format(data.updatedDate)}
		</span>
	)}
	{!!data.tags?.length && data.tags.map((tag) => (
		<a data-pagefind-filter={`tag:${tag}`} href={`/tags/${tag}/`}>
			<span class="sr-only">View more blogs with the tag&nbsp;</span>{tag}
		</a>
	))}
</div>

<script>
	// US-015 相對時間
	const timeEls = document.querySelectorAll('.relative-time');
	timeEls.forEach((el) => {
		const date = new Date(el.getAttribute('datetime')!);
		const now = new Date();
		const diffTime = now.getTime() - date.getTime();
		const diffDays = Math.floor(diffTime / (1000 * 60 * 60 * 24));
		if (diffDays > 0) {
			el.innerHTML += ` <span class="text-[0.8rem] text-muted/70 font-normal">（${diffDays} 天前）</span>`;
		} else if (diffDays === 0) {
			el.innerHTML += ` <span class="text-[0.8rem] text-muted/70 font-normal">（今天）</span>`;
		}
	});
</script>

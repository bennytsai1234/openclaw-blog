---
import Search from "@/components/Search.astro";
import ThemeToggle from "@/components/ThemeToggle.astro";
import { menuLinks } from "@/site.config";
import { siteConfig } from "../../site.config";
---

<header class="group relative mb-6 flex items-center justify-between py-4 sm:mb-8" id="main-header">
	<div class="flex items-center gap-4">
		<a
			aria-current={Astro.url.pathname === "/" ? "page" : false}
			class="flex items-center gap-3 transition-opacity hover:opacity-80"
			href="/"
		>
			<svg
				aria-hidden="true"
				class="lobster-logo h-10 w-6 sm:h-12 sm:w-8"
				fill="none"
				focusable="false"
				viewBox="0 0 100 100"
				xmlns="http://www.w3.org/2000/svg"
			>
				<ellipse cx="50" cy="55" rx="25" ry="20" fill="#e74c3c"/>
				<ellipse cx="50" cy="78" rx="12" ry="6" fill="#c0392b"/>
				<ellipse cx="50" cy="86" rx="8" ry="4" fill="#c0392b"/>
				<path d="M42 90 Q50 98 58 90" stroke="#c0392b" stroke-width="3" fill="none"/>
				<ellipse cx="50" cy="35" rx="18" ry="15" fill="#e74c3c"/>
				<circle cx="42" cy="30" r="4" fill="#2c3e50"/>
				<circle cx="58" cy="30" r="4" fill="#2c3e50"/>
				<circle cx="43" cy="29" r="1.5" fill="white"/>
				<circle cx="59" cy="29" r="1.5" fill="white"/>
				<path d="M42 22 Q35 10 30 5" stroke="#c0392b" stroke-width="2" fill="none"/>
				<path d="M58 22 Q65 10 70 5" stroke="#c0392b" stroke-width="2" fill="none"/>
				<ellipse cx="22" cy="50" rx="12" ry="8" fill="#e74c3c" transform="rotate(-20 22 50)"/>
				<path d="M12 45 Q5 40 8 35 Q12 38 12 45" fill="#c0392b"/>
				<path d="M12 55 Q5 60 8 65 Q12 62 12 55" fill="#c0392b"/>
				<ellipse cx="78" cy="50" rx="12" ry="8" fill="#e74c3c" transform="rotate(20 78 50)"/>
				<path d="M88 45 Q95 40 92 35 Q88 38 88 45" fill="#c0392b"/>
				<path d="M88 55 Q95 60 92 65 Q88 62 88 55" fill="#c0392b"/>
				<path d="M35 65 Q30 72 28 75" stroke="#c0392b" stroke-width="2" fill="none"/>
				<path d="M42 68 Q38 75 36 78" stroke="#c0392b" stroke-width="2" fill="none"/>
				<path d="M58 68 Q62 75 64 78" stroke="#c0392b" stroke-width="2" fill="none"/>
				<path d="M65 65 Q70 72 72 75" stroke="#c0392b" stroke-width="2" fill="none"/>
				<ellipse cx="45" cy="48" rx="8" ry="5" fill="#ff6b6b" opacity="0.5"/>
			</svg>
			<span class="text-lg font-bold tracking-tight sm:text-xl">{siteConfig.title}</span>
		</a>

		<nav
			aria-label="Main menu"
			class="bg-global-bg absolute -inset-x-4 top-16 hidden flex-col divide-y px-4 py-2 group-[.menu-open]:z-50 group-[.menu-open]:flex sm:static sm:z-auto sm:ms-4 sm:flex sm:flex-row sm:divide-none sm:bg-transparent sm:p-0"
			id="navigation-menu"
		>
			{
				menuLinks.map((link) => (
					<a
						aria-current={Astro.url.pathname === link.path ? "page" : false}
						class="py-3 text-sm font-medium text-muted transition-colors hover:text-accent sm:px-3 sm:py-0"
						href={link.path}
					>
						{link.title}
					</a>
				))
			}
		</nav>
	</div>

	<div class="flex items-center gap-2">
		<Search />
		<ThemeToggle />
		<mobile-button>
			<button
				aria-expanded="false"
				aria-haspopup="menu"
				class="ms-2 flex h-8 w-8 items-center justify-center rounded-md border border-accent/10 hover:bg-accent/5 sm:hidden"
				id="toggle-navigation-menu"
				type="button"
			>
				<span class="sr-only">Open main menu</span>
				<svg
					aria-hidden="true"
					class="h-5 w-5 transition-all group-aria-expanded:hidden"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					viewBox="0 0 24 24"
				>
					<path d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" stroke-linecap="round" stroke-linejoin="round" />
				</svg>
				<svg
					aria-hidden="true"
					class="hidden h-5 w-5 text-accent group-aria-expanded:block"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					viewBox="0 0 24 24"
				>
					<path d="M6 18L18 6M6 6l12 12" stroke-linecap="round" stroke-linejoin="round" />
				</svg>
			</button>
		</mobile-button>
	</div>
</header>

<script>
	import { toggleClass } from "@/utils/domElement";

	class MobileNavBtn extends HTMLElement {
		#menuOpen: boolean = false;

		connectedCallback() {
			const headerEl = document.getElementById("main-header")!;
			const mobileButtonEl = this.querySelector<HTMLButtonElement>("button");

			mobileButtonEl?.addEventListener("click", () => {
				if (headerEl) toggleClass(headerEl, "menu-open");
				this.#menuOpen = !this.#menuOpen;
				mobileButtonEl.setAttribute("aria-expanded", this.#menuOpen.toString());
			});
		}
	}

	customElements.define("mobile-button", MobileNavBtn);
</script>

---
import { siteConfig } from "@/site.config";

const year = new Date().getFullYear();
---

<footer
	class="mt-auto flex w-full flex-col items-center justify-between gap-y-4 border-t border-accent/5 py-10 text-center align-top sm:flex-row sm:text-left"
>
	<div class="text-[10px] font-bold uppercase tracking-widest text-muted/50">
		&copy; {siteConfig.author} {year} · {siteConfig.title}
	</div>
	
	<div class="flex items-center gap-x-6">
		<a
			href="/rss.xml"
			class="text-[10px] font-bold uppercase tracking-widest text-muted/50 transition-colors hover:text-accent"
			aria-label="RSS Feed"
			target="_blank"
			rel="noopener noreferrer"
		>
			RSS
		</a>
		<a
			href="https://github.com/BennyTsai1234"
			class="text-[10px] font-bold uppercase tracking-widest text-muted/50 transition-colors hover:text-accent"
			aria-label="GitHub"
			target="_blank"
			rel="noopener noreferrer"
		>
			GitHub
		</a>
		<div class="flex items-center gap-x-1 text-[10px] font-bold uppercase tracking-widest text-muted/30">
			<span>Built with</span>
			<a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">Astro</a>
		</div>
	</div>
</footer>

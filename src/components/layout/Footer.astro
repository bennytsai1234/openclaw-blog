---
import { menuLinks, siteConfig } from "@/site.config";

const year = new Date().getFullYear();
---

<footer
	class="text-muted mt-auto flex w-full flex-col items-center justify-center gap-y-3 pt-20 pb-4 text-center align-top font-semibold sm:flex-row sm:justify-between sm:text-xs"
>
	<div class="me-0 sm:me-4 flex flex-col sm:flex-row items-center gap-x-2 gap-y-1">
		<span>
			&copy; {siteConfig.author}
			{year}.<span class="inline-block">&nbsp;🚀&nbsp;{siteConfig.title}&nbsp;🦞&nbsp;</span>
		</span>
		<span class="hidden sm:inline">·</span>
		<span class="flex items-center gap-x-2">
			<a
				href="/rss.xml"
				class="hover:text-global-text inline-flex items-center gap-1 hover:underline"
				aria-label="RSS Feed"
				target="_blank"
				rel="noopener noreferrer"
			>
				<svg
					xmlns="http://www.w3.org/2000/svg"
					width="14"
					height="14"
					viewBox="0 0 24 24"
					fill="currentColor"
					aria-hidden="true"
				>
					<path
						d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"
					/>
				</svg>
				<span>RSS</span>
			</a>
			<a
				href="https://github.com/BennyTsai1234"
				class="hover:text-global-text inline-flex items-center gap-1 hover:underline"
				aria-label="GitHub"
				target="_blank"
				rel="noopener noreferrer"
			>
				<svg
					xmlns="http://www.w3.org/2000/svg"
					width="14"
					height="14"
					viewBox="0 0 24 24"
					fill="currentColor"
					aria-hidden="true"
				>
					<path
						d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"
					/>
				</svg>
				<span>GitHub</span>
			</a>
		</span>
	</div>
	<nav aria-labelledby="footer_links" class="sm:divide-muted flex flex-wrap justify-center gap-x-2 gap-y-1 sm:gap-x-0 sm:divide-x">
		<p id="footer_links" class="sr-only">More on this site</p>
		{
			menuLinks.map((link) => (
				<a class="hover:text-global-text px-4 py-2 hover:underline sm:py-0" href={link.path}>
					{link.title}
				</a>
			))
		}
	</nav>
	<div class="flex items-center gap-x-2 text-xs text-muted">
		<a
			href="https://vercel.com"
			target="_blank"
			rel="noopener noreferrer"
			class="hover:text-global-text inline-flex items-center gap-1 hover:underline"
			aria-label="Powered by Vercel"
		>
			<svg width="14" height="14" viewBox="0 0 76 65" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
				<path d="M37.5274 0L75.0548 65H0L37.5274 0Z" fill="currentColor"/>
			</svg>
			<span>Vercel</span>
		</a>
		<span>+</span>
		<a
			href="https://astro.build"
			target="_blank"
			rel="noopener noreferrer"
			class="hover:text-global-text inline-flex items-center gap-1 hover:underline"
			aria-label="Powered by Astro"
		>
			<svg width="14" height="14" viewBox="0 0 256 255" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
				<defs>
					<linearGradient id="astro-gradient" x1="-.828%" x2="57.636%" y1="7.652%" y2="78.411%">
						<stop offset="0%" stop-color="#FF5D01"/>
						<stop offset="100%" stop-color="#FF1639"/>
					</linearGradient>
				</defs>
				<path fill="url(#astro-gradient)" d="M240.6 194.3c-1.5 3.2-4.2 5.4-8.1 5.5-19.8.4-46.3.4-66.1 0-3.9-.1-6.5-2.2-8.1-5.5-2.1-4.7-1.8-11.1 1.1-18.6 11.4-30.2 37.5-47.9 64.9-64.3 8.2-4.9 8.2-7.8 7.4-10.8-2.7-9.4-12.3-15.1-23.7-15.1-12 0-22.8 6.6-24.7 16.6-1.9 10 4.7 14.5 12 18.5 2.9 1.6 7.7 3.3 11.9 5.2-16.3 6.9-34.5 14.7-45.5 24.5-10.4 9.3-19.7 24.1-14.3 44.1 5.4 20 21.7 32.4 43.5 32.4 18.2 0 33.9-8.9 41.2-24.1 1.6-3.4 3.1-6.4 4.5-9.1l.6-1.3c-6.4-2.5-11.9-5.1-15.8-7.4-4.2-2.5-6.5-5.6-6.4-8.5.2-3 2.8-4.9 6.6-4.9 2.9 0 5.4 1.1 6.6 2.9 1.1 1.5 1.3 3.1.7 4.3-.2.4-.6.9-1.1 1.5 2.7 1.1 5.5 2.2 8.4 3.2 1.1.4 2.1.8 3.1 1.2.4-1.1.7-2.2.9-3.3 1.5-6.9-.2-11.9-3.2-15.2-2.8-3-7.3-4.6-12.3-4.6-7.5 0-14.1 3.2-18.2 8.7-4.2 5.7-6.4 13.7-4.6 21.9 1.9 8.6 7.8 16.2 16.5 21.2 2.7 1.6 4.7 2.9 6.3 4 7.6 5 12.9 8.5 18.3 9.2 1.4.2 2.7.3 3.9.3 6.3 0 10.6-3 12.6-8.4 1.3-3.3 2.5-7.2 3.5-11.5z"/>
				</svg>
			<span>Astro</span>
		</a>
	</div>
</footer>
